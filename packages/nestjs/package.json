{
  "name": "@tahanabavi/typewire-nestjs",
  "version": "0.1.0",
  "description": "NestJS integration for the TypeWire ecosystem — bind routes and validate request/response on the backend using the exact same Zod contracts your frontend consumes (typefetch HTTP today; typesocket gateways planned).",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "typewire",
    "nestjs",
    "typefetch",
    "typesocket",
    "websocket",
    "zod",
    "zod-contracts",
    "contracts",
    "validation",
    "type-safe",
    "api",
    "rest",
    "backend",
    "full-stack",
    "end-to-end-typesafety"
  ],
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@nestjs/swagger": "^7.0.0 || ^8.0.0 || ^11.0.0",
    "@tahanabavi/typefetch": ">=1.6.0",
    "crypto-js": "^4.0.0",
    "node-forge": "^1.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/swagger": {
      "optional": true
    },
    "crypto-js": {
      "optional": true
    },
    "node-forge": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.4.6",
    "@nestjs/testing": "^11.0.0",
    "@tahanabavi/typefetch": "workspace:*",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/node-forge": "^1.3.14",
    "@types/supertest": "^6.0.2",
    "crypto-js": "^4.2.0",
    "jest": "^30.1.3",
    "node-forge": "^1.4.0",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.0.1",
    "rxjs": "^7.8.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "zod": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "Taha Nabavi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TahaNabavi/typewire.git",
    "directory": "packages/nestjs"
  },
  "bugs": {
    "url": "https://github.com/TahaNabavi/typewire/issues"
  },
  "homepage": "https://www.tahanabavi.ir/docs/typefetch",
  "publishConfig": {
    "access": "public"
  }
}
