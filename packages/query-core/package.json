{
  "name": "@tahanabavi/typefetch-query-core",
  "version": "0.0.0",
  "private": true,
  "description": "Framework-agnostic query engine for TypeFetch contracts (cache, dedup, staleness, mutations, invalidation).",
  "author": {
    "name": "Taha Nabavi",
    "email": "sayyedtahanabavi@gmail.com",
    "url": "https://www.tahanabavi.ir"
  },
  "license": "MIT",
  "keywords": [
    "typewire",
    "typefetch",
    "query",
    "cache",
    "dedup",
    "staleness",
    "mutations",
    "invalidation",
    "zod",
    "type-safe",
    "data-fetching"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
