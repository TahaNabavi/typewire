{
  "name": "@typewire-examples/chat",
  "version": "0.0.1",
  "private": true,
  "description": "Real-time chat built on one typesocket contract — socket.io server, React UI, live frame inspector.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c magenta,cyan \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tahanabavi/typesocket": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2",
    "vite": "^6.0.0"
  }
}
